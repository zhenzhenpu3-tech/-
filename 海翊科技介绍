<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOVORIK-X | 全球智能户外解决方案领导者</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-dark: #0a0a0a;
            --secondary-dark: #1a1a1a;
            --accent-green: #00ff9d;
            --accent-dark-green: #00cc7a;
            --accent-light-green: #a3ffd9;
            --accent-gold: #ffd700;
            --text-primary: #ffffff;
            --text-secondary: #cccccc;
            --gradient-bg: linear-gradient(135deg, #0a0a0a 0%, #0a2a1a 30%, #1a3a2a 60%, #2a4a3a 100%);
            --gradient-green: linear-gradient(90deg, #00ff9d 0%, #00cc7a 100%);
            --gradient-title: linear-gradient(90deg, #ffffff 0%, #a3ffd9 50%, #00ff9d 100%);
            --gradient-button: linear-gradient(135deg, rgba(0, 40, 20, 0.8) 0%, rgba(0, 60, 30, 0.6) 50%, rgba(0, 80, 40, 0.4) 100%);
            --gradient-header: linear-gradient(90deg, rgba(0, 60, 30, 0.9) 0%, rgba(10, 10, 10, 0.9) 100%);
            --card-bg: rgba(30, 30, 30, 0.5);
            --border-radius: 16px;
            --transition: all 0.3s ease;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            --glow: 0 0 20px rgba(0, 255, 157, 0.3);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--gradient-bg);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* 三色高端背景：黑色+深绿色渐变+白色渐变 */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(
                    circle at 90% 10%,
                    rgba(255, 255, 255, 0.05) 0%,
                    transparent 20%
                ),
                radial-gradient(
                    circle at 20% 80%,
                    rgba(0, 60, 30, 0.4) 0%,
                    transparent 40%
                ),
                linear-gradient(
                    135deg,
                    rgba(0, 0, 0, 1) 0%,
                    rgba(10, 30, 20, 0.9) 30%,
                    rgba(20, 50, 40, 0.8) 60%,
                    rgba(30, 70, 60, 0.7) 100%
                );
            z-index: -1;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* 头部样式 - 优化为从右侧绿色渐变到左侧黑色 */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: var(--gradient-header);
            backdrop-filter: blur(10px);
            padding: 10px 0;
            border-bottom: 1px solid rgba(0, 255, 157, 0.1);
            transition: var(--transition);
        }

        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 60px;
        }

        .logo {
            display: flex;
            align-items: center;
            text-decoration: none;
            font-size: 24px;
            font-weight: 900;
            font-family: 'Arial Black', Impact, sans-serif;
        }

        .logo-black {
            color: #000000;
        }

        .logo-green {
            color: #32CD32;
        }

        .logo-text {
            color: #000000;
            font-family: 'Arial Black', sans-serif;
            letter-spacing: 1px;
        }

        .logo-text-green {
            color: #00FF9D;
            font-family: 'Arial Black', sans-serif;
            letter-spacing: 1px;
        }

        /* 主横幅区域 */
        .hero {
            padding: 200px 0 150px;
            background: 
                linear-gradient(rgba(10, 10, 10, 0.6), rgba(10, 10, 10, 0.7)),
                url('https://i.imgur.com/3Msinge.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(
                circle at 70% 30%,
                rgba(0, 255, 157, 0.1) 0%,
                transparent 50%
            );
        }

        .hero-content {
            max-width: 900px;
            position: relative;
            z-index: 2;
            text-align: center;
            margin: 0 auto;
        }

        /* 优化主标题：添加空格，两句话用空格分隔 */
        .hero h1 {
            font-size: 4.2rem;
            line-height: 1.1;
            margin-bottom: 20px;
            background: var(--gradient-title);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 800;
            text-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
            letter-spacing: 0.5px;
        }

        /* 优化副标题 */
        .hero-subtitle {
            font-size: 2rem;
            color: var(--accent-light-green);
            margin-bottom: 40px;
            font-weight: 300;
            text-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
        }

        .cta-button {
            display: inline-block;
            background: var(--gradient-button);
            color: var(--text-primary);
            padding: 18px 40px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
            border: none;
            cursor: pointer;
            font-size: 18px;
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
            border: 2px solid rgba(0, 255, 157, 0.3);
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            transition: 0.5s;
        }

        .cta-button:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: var(--glow);
            background: linear-gradient(135deg, rgba(0, 60, 30, 0.8) 0%, rgba(0, 80, 40, 0.6) 50%, rgba(0, 100, 50, 0.4) 100%);
        }

        .cta-button:hover::before {
            left: 100%;
        }

        /* 通用部分样式 - 标题全部居中 */
        section {
            padding: 100px 0;
            text-align: center;
        }

        .section-title {
            font-size: 3rem;
            margin-bottom: 20px;
            position: relative;
            display: inline-block;
            text-align: center;
            background: var(--gradient-title);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 4px;
            background: var(--gradient-green);
            border-radius: 2px;
        }

        .section-subtitle {
            color: var(--accent-green);
            font-size: 1.3rem;
            margin-bottom: 50px;
            text-align: center;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            font-weight: 300;
        }

        /* 卡片样式 - 优化背景为透明渐变 */
        .card {
            background: linear-gradient(135deg, rgba(30, 30, 30, 0.5) 0%, rgba(40, 50, 40, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 35px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            border: 1px solid rgba(255, 255, 255, 0.05);
            height: 100%;
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: var(--gradient-green);
        }

        .card:hover {
            transform: translateY(-15px) scale(1.02);
            border-color: rgba(0, 255, 157, 0.3);
            box-shadow: 0 20px 40px rgba(0, 255, 157, 0.1);
        }

        .card-title {
            font-size: 1.6rem;
            margin-bottom: 20px;
            color: var(--accent-light-green);
            text-align: center;
        }

        /* 关于我们部分 - 优化背景为透明渐变 */
        .about-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
            text-align: left;
        }

        .stats {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
        }

        .stat-item {
            text-align: center;
            padding: 20px;
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.4) 0%, rgba(50, 60, 50, 0.3) 100%);
            border-radius: var(--border-radius);
            flex: 1;
            margin: 0 10px;
            transition: var(--transition);
        }

        .stat-item:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.6) 0%, rgba(50, 60, 50, 0.5) 100%);
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 700;
            color: var(--accent-green);
            margin-bottom: 5px;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* 我们的使命部分 - 优化背景为透明渐变 */
        .mission-section {
            background: linear-gradient(135deg, rgba(0, 20, 10, 0.2) 0%, rgba(0, 30, 15, 0.1) 100%);
        }

        .mission-content {
            max-width: 1000px;
            margin: 0 auto;
            text-align: left;
        }

        .mission-item {
            margin-bottom: 40px;
            padding: 35px;
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.4) 0%, rgba(50, 60, 50, 0.3) 100%);
            border-radius: var(--border-radius);
            border-left: 5px solid var(--accent-green);
            transition: var(--transition);
        }

        .mission-item:hover {
            transform: translateX(10px);
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.6) 0%, rgba(50, 60, 50, 0.5) 100%);
        }

        .mission-title {
            font-size: 1.8rem;
            color: var(--accent-green);
            margin-bottom: 15px;
        }

        /* OPE市场重要性部分 - 优化背景为透明渐变 */
        .ope-market-section {
            background: linear-gradient(135deg, rgba(0, 20, 10, 0.3) 0%, rgba(0, 30, 15, 0.2) 100%);
        }

        .ope-market-content {
            text-align: left;
            max-width: 1000px;
            margin: 0 auto;
        }

        .ope-section {
            margin-bottom: 50px;
        }

        .ope-section-title {
            font-size: 2.2rem;
            color: var(--accent-green);
            margin-bottom: 20px;
            border-left: 5px solid var(--accent-green);
            padding-left: 20px;
        }

        .ope-subtitle {
            font-size: 1.4rem;
            color: var(--accent-light-green);
            margin-bottom: 15px;
        }

        .ope-market-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin: 30px 0;
        }

        .market-stat {
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.5) 0%, rgba(50, 60, 50, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 25px;
            text-align: center;
            transition: var(--transition);
        }

        .market-stat:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.7) 0%, rgba(50, 60, 50, 0.6) 100%);
        }

        .market-stat-value {
            font-size: 2.5rem;
            color: var(--accent-green);
            font-weight: 700;
            margin-bottom: 10px;
        }

        .market-stat-label {
            color: var(--text-secondary);
            font-size: 1rem;
        }

        .power-source-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 30px;
        }

        .power-source-item {
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.5) 0%, rgba(50, 60, 50, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 25px;
            text-align: left;
            transition: var(--transition);
        }

        .power-source-item:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.7) 0%, rgba(50, 60, 50, 0.6) 100%);
        }

        .power-source-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .power-source-name {
            font-size: 1.4rem;
            color: var(--accent-green);
        }

        .power-source-percentage {
            font-size: 2rem;
            color: var(--accent-light-green);
            font-weight: 700;
        }

        .power-source-advantages, .power-source-limitations {
            margin-top: 15px;
        }

        .power-source-subtitle {
            color: var(--accent-light-green);
            font-size: 1.1rem;
            margin-bottom: 8px;
        }

        /* 产品展示部分 - 优化背景为透明渐变 */
        .product-showcase {
            background: linear-gradient(135deg, rgba(0, 20, 10, 0.2) 0%, rgba(0, 30, 15, 0.1) 100%);
        }

        .product-full-image {
            width: 100%;
            height: 500px;
            border-radius: var(--border-radius);
            margin-bottom: 60px;
            overflow: hidden;
            position: relative;
            box-shadow: var(--shadow);
        }

        .product-full-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .product-full-image:hover img {
            transform: scale(1.05);
        }

        /* 三大产品线板块 - 一行三个小板块，优化背景为透明渐变 */
        .product-categories {
            display: flex;
            justify-content: space-between;
            gap: 30px;
            margin-top: 50px;
        }

        .product-category {
            text-align: center;
            flex: 1;
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.5) 0%, rgba(50, 60, 50, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 30px 25px;
            transition: var(--transition);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .product-category:hover {
            transform: translateY(-10px) scale(1.05);
            border-color: rgba(0, 255, 157, 0.3);
            box-shadow: 0 15px 30px rgba(0, 255, 157, 0.1);
        }

        .category-icon {
            font-size: 3rem;
            color: var(--accent-green);
            margin-bottom: 25px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .category-title {
            font-size: 1.6rem;
            margin-bottom: 20px;
            color: var(--accent-green);
        }

        /* AI IoT生态部分 - 新增板块 */
        .ai-iot-section {
            background: linear-gradient(135deg, rgba(0, 20, 10, 0.3) 0%, rgba(0, 30, 15, 0.2) 100%);
        }

        .ai-iot-content {
            text-align: left;
            max-width: 1000px;
            margin: 0 auto;
        }

        .ai-iot-intro {
            font-size: 1.3rem;
            line-height: 1.8;
            margin-bottom: 40px;
            text-align: center;
        }

        .ai-iot-columns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 50px;
        }

        .ai-iot-column {
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.5) 0%, rgba(50, 60, 50, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 35px;
            transition: var(--transition);
        }

        .ai-iot-column:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 255, 157, 0.1);
        }

        .ai-iot-column-title {
            font-size: 1.8rem;
            color: var(--accent-green);
            margin-bottom: 20px;
            text-align: center;
        }

        .value-commitment-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 40px;
        }

        .value-item {
            background: linear-gradient(135deg, rgba(40, 40, 40, 0.5) 0%, rgba(50, 60, 50, 0.4) 100%);
            border-radius: var(--border-radius);
            padding: 30px;
            text-align: center;
            transition: var(--transition);
        }

        .value-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 255, 157, 0.1);
        }

        .value-icon {
            font-size: 2.5rem;
            color: var(--accent-green);
            margin-bottom: 20px;
        }

        .value-title {
            font-size: 1.4rem;
            color: var(--accent-light-green);
            margin-bottom: 15px;
        }

        /* 核心壁垒部分 - 优化背景为透明渐变 */
        .barriers-section {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.3) 0%, rgba(0, 20, 10, 0.2) 100%);
        }

        .barriers-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
            margin-top: 50px;
        }

        .barrier-item {
            text-align: center;
        }

        .barrier-icon {
            font-size: 3rem;
            color: var(--accent-green);
            margin-bottom: 25px;
        }

        .barrier-title {
            font-size: 1.6rem;
            margin-bottom: 20px;
            color: var(--accent-light-green);
        }

        /* 办公地点部分 - 优化背景为透明渐变 */
        .locations-section {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 20, 10, 0.3) 100%);
            padding: 100px 0;
        }

        .locations {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
        }

        .location-card {
            text-align: center;
            padding: 30px;
        }

        .location-icon {
            font-size: 2.2rem;
            color: var(--accent-green);
            margin-bottom: 20px;
        }

        .location-title {
            font-size: 1.4rem;
            margin-bottom: 15px;
            color: var(--accent-light-green);
        }

        /* 通用按钮样式 */
        .section-button {
            display: inline-block;
            background: var(--gradient-button);
            color: var(--text-primary);
            padding: 15px 35px;
            border-radius: 50px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
            border: 2px solid rgba(0, 255, 157, 0.3);
            font-size: 16px;
            box-shadow: var(--shadow);
            margin-top: 20px;
        }

        .section-button:hover {
            transform: translateY(-5px);
            box-shadow: var(--glow);
            background: linear-gradient(135deg, rgba(0, 60, 30, 0.8) 0%, rgba(0, 80, 40, 0.6) 50%, rgba(0, 100, 50, 0.4) 100%);
        }

        /* 页脚 */
        footer {
            background: linear-gradient(135deg, rgba(10, 20, 15, 0.9) 0%, rgba(20, 30, 25, 0.8) 100%);
            padding: 80px 0 40px;
            border-top: 1px solid rgba(0, 255, 157, 0.1);
            text-align: left;
        }

        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 50px;
            margin-bottom: 60px;
        }

        .footer-column h3 {
            font-size: 1.4rem;
            margin-bottom: 30px;
            color: var(--accent-light-green);
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 15px;
        }

        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            display: inline-block;
        }

        .footer-links a:hover {
            color: var(--accent-green);
            transform: translateX(5px);
        }

        .copyright {
            text-align: center;
            padding-top: 40px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* 响应式设计 */
        @media (max-width: 1200px) {
            .locations {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .barriers-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .hero h1 {
                font-size: 3.5rem;
            }
            
            .ope-market-stats, .power-source-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .ai-iot-columns, .value-commitment-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 992px) {
            .about-content {
                grid-template-columns: 1fr;
                text-align: center;
            }
            
            .product-categories {
                flex-wrap: wrap;
            }
            
            .product-category {
                flex: 1 0 calc(50% - 20px);
                min-width: 250px;
            }
            
            .barriers-grid {
                grid-template-columns: 1fr;
            }
            
            .locations {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .hero h1 {
                font-size: 2.8rem;
            }
            
            .hero-subtitle {
                font-size: 1.6rem;
            }
            
            .ope-market-stats, .power-source-grid {
                grid-template-columns: 1fr;
            }
            
            .ai-iot-columns, .value-commitment-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5rem;
            }
            
            .section-title {
                font-size: 2.2rem;
            }
            
            .product-categories {
                flex-direction: column;
            }
            
            .product-category {
                flex: 1 0 100%;
            }
            
            .locations {
                grid-template-columns: 1fr;
            }
            
            .hero-subtitle {
                font-size: 1.4rem;
            }
        }

        @media (max-width: 576px) {
            .hero h1 {
                font-size: 2rem;
            }
            
            .section-title {
                font-size: 1.8rem;
            }
            
            .stats {
                flex-direction: column;
                gap: 20px;
            }
            
            .stat-item {
                margin: 0 0 20px 0;
            }
            
            .hero-subtitle {
                font-size: 1.2rem;
